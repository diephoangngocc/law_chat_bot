# Chế độ mặc định: no_llm hoặc local_llm
ANSWER_MODE=no_llm

# Dữ liệu KG. Mặc định là ./data
DATA_DIR=./data

# Local LLM qua Ollama. Chỉ cần khi ANSWER_MODE=local_llm hoặc request use_llm=true
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen3:4b
LOCAL_LLM_TIMEOUT=120

# Retrieval
TOP_K=5
KG_EXPAND_DEPTH=1
