# ─── Chế độ trả lời ────────────────────────────────────────────────────────────
# no_llm   : dùng template (không cần Ollama/LM Studio, nhanh, ổn định)
# local_llm: gọi LLM local để sinh câu trả lời tự nhiên hơn
ANSWER_MODE=no_llm

# ─── Dữ liệu KG ────────────────────────────────────────────────────────────────
DATA_DIR=./data

# ─── Retrieval ──────────────────────────────────────────────────────────────────
TOP_K=5
KG_EXPAND_DEPTH=1

# ─── LLM Provider ───────────────────────────────────────────────────────────────
# ollama            : Ollama chạy local (mặc định)
# lmstudio          : LM Studio OpenAI-compatible local server
# openai_compatible : bất kỳ server OpenAI-compatible nào khác
LLM_PROVIDER=ollama

# ─── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen3:4b
LOCAL_LLM_TIMEOUT=180

# ─── LM Studio / OpenAI-compatible ──────────────────────────────────────────────
# Dùng khi LLM_PROVIDER=lmstudio hoặc openai_compatible
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL=auto   # "auto" sẽ tự lấy model đầu tiên đang load trong LM Studio
LOCAL_LLM_API_KEY=lm-studio
